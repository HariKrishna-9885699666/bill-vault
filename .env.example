# BillVault — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Google Drive Integration ──────────────────────────────────────────────────
# Required for uploading bill attachments to Google Drive.
# The app works fully offline without these — attachments are stored locally
# in IndexedDB and can optionally sync to Drive when credentials are configured.

# Step 1: Create a project at https://console.cloud.google.com
# Step 2: Enable the Google Drive API
# Step 3: Create OAuth 2.0 Client ID credentials (Web app type)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Step 4: Get a refresh token via https://developers.google.com/oauthplayground
#   - Select scope: https://www.googleapis.com/auth/drive.file
#   - Exchange the auth code for tokens and paste the refresh_token here
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Also expose the client ID to the browser for future OAuth PKCE flow support
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ── TanStack Start / Vite ─────────────────────────────────────────────────────
# No additional variables are required for local development without Drive.
# Add VITE_* prefixed variables here to expose values to the client bundle.
